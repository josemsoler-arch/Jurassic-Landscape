# Database
DATABASE_URL="postgresql://user:password@localhost:5432/jurassic_landscape?schema=public"

# Server
PORT=5000
NODE_ENV=development

# Frontend
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration
# Recipient email - where client contact forms are sent
EMAIL_TO=your-email@example.com

# Sender email configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password-here
